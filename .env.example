# ══════════════════════════════════════════════════════════════
# .env.example — Hub de Automações Ciamed
# ══════════════════════════════════════════════════════════════
# Copie este arquivo como ".env" e preencha os valores.
# O .env NUNCA deve ir pro Git (já está no .gitignore).
# ══════════════════════════════════════════════════════════════

# ── AMBIENTE ──────────────────────────────────────────────────
# "dev" = seu PC (usa Postgres e N8N locais)
# "prod" = servidor da Ciamed (usa Postgres e N8N de produção)
AMBIENTE=

# ── FLASK ─────────────────────────────────────────────────────
# OBRIGATÓRIA. Sem ela o app não sobe (por segurança — assina o login).
# Gere uma chave forte com:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ── BANCO DE DADOS (PostgreSQL) ───────────────────────────────
# Dev:  postgresql://hub_user:hub_local_2026@localhost:5432/hub_automacoes
# Prod: postgresql://USUARIO:SENHA@IP_SERVIDOR:5432/hub_automacoes
DATABASE_URL=

# ── N8N WEBHOOKS ──────────────────────────────────────────────
# Dev:  http://localhost:5678/webhook/...
# Prod: https://ciamedrs.app.n8n.cloud/webhook/...
N8N_WEBHOOK_CADASTRO=

# Usado pelo botão "reprocessar cadastro".
N8N_WEBHOOK_REPROCESSAR=

# "Crachá secreto" entre N8N e Hub (V-03). Enquanto VAZIO, os webhooks do
# N8N ficam SEM proteção (o Hub avisa no log). Para LIGAR a proteção:
#   1) gere um segredo:  python -c "import secrets; print(secrets.token_urlsafe(32))"
#   2) cole o valor aqui no Hub
#   3) no N8N, em CADA nó HTTP Request que chama o Hub, adicione o header:
#        X-Hub-Token: <mesmo valor>
N8N_HUB_TOKEN=

# (Opcional) Anti-SSRF: hosts extras que o Hub pode "visitar" na resume_url,
# além dos derivados dos webhooks acima. Formato: host:porta separados por vírgula.
# Normalmente NÃO precisa preencher — o host do N8N já é deduzido dos webhooks.
# Ex.: N8N_RESUME_HOSTS=ciamedrs.app.n8n.cloud
N8N_RESUME_HOSTS=

# ── CREDENCIAIS DO ERP (NLWEB) ───────────────────────────────
NLWEB_URL=
NLWEB_USER=
NLWEB_PASS=
