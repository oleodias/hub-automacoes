# ══════════════════════════════════════════════════════════════
# .env.example — Hub de Automações Ciamed
# ══════════════════════════════════════════════════════════════
# Copie este arquivo como ".env" e preencha os valores.
# O .env NUNCA deve ir pro Git (já está no .gitignore).
# ══════════════════════════════════════════════════════════════

# ── AMBIENTE ──────────────────────────────────────────────────
# "dev" = seu PC (usa Postgres e N8N locais)
# "prod" = servidor da Ciamed (usa Postgres e N8N de produção)
AMBIENTE=

# ── FLASK ─────────────────────────────────────────────────────
FLASK_SECRET_KEY=

# ── BANCO DE DADOS (PostgreSQL) ───────────────────────────────
# Dev:  postgresql://hub_user:hub_local_2026@localhost:5432/hub_automacoes
# Prod: postgresql://USUARIO:SENHA@IP_SERVIDOR:5432/hub_automacoes
DATABASE_URL=

# ── N8N WEBHOOKS ──────────────────────────────────────────────
# Dev:  http://localhost:5678/webhook/...
# Prod: https://ciamedrs.app.n8n.cloud/webhook/...
N8N_WEBHOOK_CADASTRO=

# ── CREDENCIAIS DO ERP (NLWEB) ───────────────────────────────
NLWEB_URL=
NLWEB_USER=
NLWEB_PASS=
