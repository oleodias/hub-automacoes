# ══════════════════════════════════════════════════════════════
# .env.prod.example — PRODUÇÃO (servidor, dados REAIS)
# ══════════════════════════════════════════════════════════════
# No servidor, copie como ".env.producao" e preencha:
#   cp .env.prod.example .env.producao
# Este arquivo (real) NUNCA vai pro Git. Trate as senhas com cuidado.
#
# É praticamente igual ao de homologação — muda o schema do Oracle
# (HUB_PROD) e os segredos/credenciais, que devem ser os de produção.
# ══════════════════════════════════════════════════════════════

# Produção: debug desligado, cookies seguros (HTTPS) e HSTS ligados.
AMBIENTE=prod

# OBRIGATÓRIA. Gere uma EXCLUSIVA de produção (nunca reaproveite a de homolog):
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# URL pública dos links de ficha enviados a clientes EXTERNOS.
# O Hub monta o link com esta base, então ele funciona fora da rede.
# Use o domínio público que o Nginx expõe SÓ para as fichas (sem barra no fim):
PUBLIC_BASE_URL=https://fichas.SEU-DOMINIO.com.br

FILA_TIMEOUT_MIN=15

# ── BANCO (Oracle da empresa — schema HUB_PROD) ──────────────
# Mesmo servidor Oracle da homologação, mas OUTRO usuário/schema:
# os dados ficam fisicamente separados (teste nunca toca produção).
DATABASE_URL=oracle+oracledb://HUB_PROD:SENHA@oracle-empresa:1521/?service_name=ORCLPDB1

# ── N8N (produção) ───────────────────────────────────────────
N8N_WEBHOOK_CADASTRO=https://ciamedrs.app.n8n.cloud/webhook/...
N8N_WEBHOOK_REPROCESSAR=https://ciamedrs.app.n8n.cloud/webhook/...
# Recomendado LIGAR a proteção dos webhooks em produção (veja docs):
N8N_HUB_TOKEN=
N8N_RESUME_HOSTS=

# ── ERP (NLWEB) ──────────────────────────────────────────────
NLWEB_URL=
NLWEB_USER=
NLWEB_PASS=
