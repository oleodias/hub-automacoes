# ══════════════════════════════════════════════════════════════
# .env.homolog.example — HOMOLOGAÇÃO (servidor, dados de TESTE)
# ══════════════════════════════════════════════════════════════
# No servidor, copie como ".env.homologacao" e preencha:
#   cp .env.homolog.example .env.homologacao
# Este arquivo (real) NUNCA vai pro Git.
#
# O QUE MUDA entre homologação e produção é basicamente o DATABASE_URL
# (schema HUB_HOMOLOG aqui, HUB_PROD na produção). O resto é igual.
# ══════════════════════════════════════════════════════════════

# Em homologação NÃO é "dev": debug desligado e cookies seguros (HTTPS) ligados.
AMBIENTE=homolog

# OBRIGATÓRIA. Gere uma PRÓPRIA para homologação (diferente da produção):
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

FILA_TIMEOUT_MIN=15

# ── BANCO (Oracle da empresa — schema HUB_HOMOLOG) ───────────
# Formato (driver "thin", não precisa do Oracle Client):
#   oracle+oracledb://USUARIO:SENHA@HOST:PORTA/?service_name=NOME_DO_SERVICO
DATABASE_URL=oracle+oracledb://HUB_HOMOLOG:SENHA@oracle-empresa:1521/?service_name=ORCLPDB1
# Enquanto o Oracle de teste não estiver pronto, dá para validar em
# homologação com um PostgreSQL de teste (basta trocar a linha acima):
# DATABASE_URL=postgresql://hub_user:SENHA@HOST:5432/hub_homolog

# ── N8N ──────────────────────────────────────────────────────
N8N_WEBHOOK_CADASTRO=
N8N_WEBHOOK_REPROCESSAR=
N8N_HUB_TOKEN=
N8N_RESUME_HOSTS=

# ── ERP (NLWEB) ──────────────────────────────────────────────
NLWEB_URL=
NLWEB_USER=
NLWEB_PASS=
