# ══════════════════════════════════════════════════════════════
# .env.dev.example — DESENVOLVIMENTO (seu PC)
# ══════════════════════════════════════════════════════════════
# Copie este arquivo como ".env" e preencha os valores.
#   cp .env.dev.example .env
# O .env NUNCA vai pro Git (já está no .gitignore).
# ══════════════════════════════════════════════════════════════

# Ambiente: "dev" liga o modo debug e desliga as travas de HTTPS.
AMBIENTE=dev

# OBRIGATÓRIA. Assina o login. Gere uma com:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Minutos até o "watchdog" considerar um robô travado e liberar a fila.
FILA_TIMEOUT_MIN=15

# ── BANCO (PostgreSQL local) ─────────────────────────────────
# Se rodar o Hub NO Windows: host = localhost
DATABASE_URL=postgresql://hub_user:hub_local_2026@localhost:5432/hub_automacoes
# Se rodar o Hub NO container (docker compose --profile app): host = postgres
# DATABASE_URL=postgresql://hub_user:hub_local_2026@postgres:5432/hub_automacoes

# ── N8N (local) ──────────────────────────────────────────────
N8N_WEBHOOK_CADASTRO=http://localhost:5678/webhook/...
N8N_WEBHOOK_REPROCESSAR=http://localhost:5678/webhook/...
N8N_HUB_TOKEN=
N8N_RESUME_HOSTS=

# ── ERP (NLWEB) ──────────────────────────────────────────────
NLWEB_URL=
NLWEB_USER=
NLWEB_PASS=
